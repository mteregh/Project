<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "EventHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      .bg-custom-dark { background-color: #1a1a2e !important; }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">EventHub</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link px-3" href="#">Events</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="#">Categories</a></li>
                    
                    <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                        <a class="nav-link btn btn-outline-light px-4" href="#">Login</a>
                    </li>
                    <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                        <a class="nav-link btn btn-light text-dark px-4 fw-semibold" href="#">Sign Up</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <%= yield %>

    <footer class="bg-custom-dark text-white text-center py-4 mt-5">
        <div class="container">
            <p class="mb-0">&copy; 2026 EventHub. Developed by Team [González, Guerra, Urzúa].</p>
            <p class="small text-muted mt-1">Web Technologies Course - Semester 202610</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
